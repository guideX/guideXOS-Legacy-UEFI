	<Target Name="RunQemuUSB" AfterTargets="BuildISO" Condition="$(vm) == 'qemuusb'">
		<Error Text="Please install QEMU in order to debug guideXOS! (do not modify the path) https://www.qemu.org/download/#windows" Condition="!Exists('C:\Program Files\qemu\qemu-system-x86_64.exe')"></Error>
		<Error Text="Please install Intel Hardware Accelerated Execution Manager (HAXM) in order to speed up QEMU https://github.com/intel/haxm/releases" Condition="!Exists('C:\Program Files\Intel\HAXM\IntelHaxm.sys')"></Error>
	    <Exec Command="&quot;C:\Program Files\qemu\qemu-system-x86_64.exe&quot; -m 2056 -smp 2 -boot d -cdrom &quot;$(MSBuildProjectDirectory)\$(NativeOutputPath)$(TargetName).iso&quot; -serial stdio -rtc base=localtime -netdev user,id=net0 -device rtl8139,netdev=net0" />
	</Target>



	<Target Name="RunQemuNET" AfterTargets="BuildISO" Condition="$(vm) == 'qemutap'">
		<Error Text="Please install QEMU in order to debug guideXOS! (do not modify the path) https://www.qemu.org/download/#windows" Condition="!Exists('C:\Program Files\qemu\qemu-system-x86_64.exe')"></Error>
		<Error Text="Please install Intel Hardware Accelerated Execution Manager (HAXM) in order to speed up QEMU https://github.com/intel/haxm/releases" Condition="!Exists('C:\Program Files\Intel\HAXM\IntelHaxm.sys')"></Error>
		<Exec Command="&quot;C:\Program Files\qemu\qemu-system-x86_64.exe&quot; -m 2056 -smp 2 -k en-us -boot d -cdrom &quot;$(MSBuildProjectDirectory)\$(NativeOutputPath)$(TargetName).iso&quot; -d guest_errors -serial stdio -device AC97 -rtc base=localtime -net nic,model=rtl8139 -net tap,ifname=tap"></Exec>
	</Target>

	<!-- UEFI Boot Target - Runs build.ps1 and launches QEMU with OVMF firmware -->
	<Target Name="RunQemuUEFI" AfterTargets="Publish" Condition="$(vm) == 'qemuuefi'">
		<Error Text="Please install QEMU in order to debug guideXOS! (do not modify the path) https://www.qemu.org/download/#windows" Condition="!Exists('C:\Program Files\qemu\qemu-system-x86_64.exe')"></Error>
		<Error Text="OVMF.fd not found! Download from https://github.com/tianocore/edk2/releases and place in repository root" Condition="!Exists('$(MSBuildStartupDirectory)\OVMF.fd')" />
		
		<!-- Run build.ps1 to build UEFI bootloader + kernel -->
		<Message Text="Building UEFI bootloader and kernel..." Importance="high" />
		<Exec Command="powershell.exe -ExecutionPolicy Bypass -File &quot;$(MSBuildStartupDirectory)\build.ps1&quot;" />
		
		<!-- Launch QEMU with UEFI - IgnoreExitCode prevents build failure when QEMU exits -->
		<Message Text="Launching QEMU with UEFI boot..." Importance="high" />
		<Exec Command="&quot;C:\Program Files\qemu\qemu-system-x86_64.exe&quot; -bios &quot;$(MSBuildStartupDirectory)\OVMF.fd&quot; -drive file=fat:rw:&quot;$(MSBuildStartupDirectory)\ESP&quot;,format=raw -m 1024M -serial stdio -no-reboot -d int,cpu_reset" IgnoreExitCode="true" />
		</Target>
	
	
	<Target Name="RunVMware" AfterTargets="BuildISO" Condition="$(vm) == 'vmware'">
		<Error Text="You must install VMWare player in order to use it!" Condition="!Exists('C:\Program Files (x86)\VMware\VMware Player\vmplayer.exe')And!Exists('C:\Program Files (x86)\VMware\VMware Workstation\vmplayer.exe')"></Error>
		<Exec Condition="Exists('C:\Program Files (x86)\VMware\VMware Workstation\vmplayer.exe')" Command="&quot;C:\Program Files (x86)\VMware\VMware Workstation\vmplayer.exe&quot; &quot;$(MSBuildStartupDirectory)\Tools\VMWare\guideXOS\guideXOS.vmx"></Exec>
		<Exec Condition="Exists('C:\Program Files (x86)\VMware\VMware Player\vmplayer.exe')And!Exists('C:\Program Files (x86)\VMware\VMware Workstation\vmplayer.exe')" Command="&quot;C:\Program Files (x86)\VMware\VMware Player\vmplayer.exe&quot; &quot;$(MSBuildStartupDirectory)\Tools\VMWare\guideXOS\guideXOS.vmx"></Exec>
	</Target>

	<Target Name="RunVMwareWorkstation" AfterTargets="BuildISO" Condition="$(vm) == 'vmwareworkstation'">
		<Error Text="You must install VMWare Workstation in order to use it!" Condition="!Exists('C:\Program Files (x86)\VMware\VMware Workstation\vmrun.exe')"></Error>
		<Exec Condition="Exists('C:\Program Files (x86)\VMware\VMware Workstation\vmrun.exe')" Command="&quot;C:\Program Files (x86)\VMware\VMware Workstation\vmrun.exe&quot; start &quot;$(MSBuildStartupDirectory)\Tools\VMWare\guideXOS\guideXOS.vmx"></Exec>
	</Target>
	
	<Target Name="RunVirtualBox" AfterTargets="BuildISO" Condition="$(vm) == 'virtualbox'">
		<Error Text="Please install Oracle VirtualBox to run GuideXOS!" Condition="!Exists('C:\Program Files\Oracle\VirtualBox\VBoxManage.exe')" />
		<Exec Command="&quot;C:\Program Files\Oracle\VirtualBox\VBoxManage.exe&quot; unregistervm GuideXOS --delete" ContinueOnError="true" />
		<Exec Command="&quot;C:\Program Files\Oracle\VirtualBox\VBoxManage.exe&quot; createvm --name GuideXOS --register" />
		<!-- Configure VM with 2GB RAM, USB support, and network adapter -->
		<Exec Command="&quot;C:\Program Files\Oracle\VirtualBox\VBoxManage.exe&quot; modifyvm GuideXOS --memory 2056 --vram 128 --acpi on --ioapic on --boot1 dvd --ostype Other_64 --mouse usbtablet --usb on --usbehci on --nic1 nat --nictype1 82540EM" />
		<Exec Command="&quot;C:\Program Files\Oracle\VirtualBox\VBoxManage.exe&quot; storagectl GuideXOS --name SATA --add sata --controller IntelAhci" />
		<Exec Command="&quot;C:\Program Files\Oracle\VirtualBox\VBoxManage.exe&quot; storageattach GuideXOS --storagectl SATA --port 0 --device 0 --type dvddrive --medium &quot;$(MSBuildProjectDirectory)\$(NativeOutputPath)$(TargetName).iso&quot;" />
		<Exec Command="&quot;C:\Program Files\Oracle\VirtualBox\VBoxManage.exe&quot; startvm GuideXOS --type gui" />
	</Target>


	<Import Project="..\Corlib\Corlib.projitems" Label="Shared" />

	<ItemGroup>
	  <PrivateSdkAssemblies Remove="Portable\**" />
	</ItemGroup>


	<ItemGroup>
	  <FrameworkAssemblies Remove="Portable\**" />
	</ItemGroup>


	<ItemGroup>
	  <Compile Remove="DefaultApps\Anomalocaris.cs" />
	  <Compile Remove="DefaultApps\Audica.cs" />
	  <Compile Remove="DefaultApps\Gorganopsid.cs" />
	  <Compile Remove="Kernel\Drivers\PS2MouseOld.cs" />
	</ItemGroup>
</Project>
