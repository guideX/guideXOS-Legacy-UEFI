<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net7.0</TargetFramework>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<BaseOutputPath>..\bin</BaseOutputPath>

		<!-- Explicitly target x64 architecture for AMD64 compatibility -->
		<PlatformTarget>x64</PlatformTarget>
		<RuntimeIdentifier>win-x64</RuntimeIdentifier>
		<Prefer32Bit>false</Prefer32Bit>

		<Optimize>true</Optimize>
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
		<ErrorOnDuplicatePublishOutputFiles>false</ErrorOnDuplicatePublishOutputFiles>

		<DefineConstants>Kernel;NETWORK;X64;UseAPIC</DefineConstants>

		<IlcSystemModule>guideXOS</IlcSystemModule>
		<!-- CRITICAL: For UEFI boot, use KMainWrapper as the entry point -->
		<!-- KMainWrapper is defined in native_stubs.asm and provides early debugging -->
		<!-- before calling into managed KMain code -->
		<EntryPointSymbol>KMainWrapper</EntryPointSymbol>
		<LinkerSubsystem>NATIVE</LinkerSubsystem>
		<!--Make the code faster!-->
		<IlcOptimizationPreference>Size</IlcOptimizationPreference>
		<!-- Allow skipping ISO build to avoid lock issues -->
		<SkipISO Condition="'$(SkipISO)'==''">false</SkipISO>
	</PropertyGroup>

	<Target Name="PrepareForILLink">
	</Target>

	<!--CustomizeReferences-->
	<Target Name="CustomizeReferences" BeforeTargets="BeforeCompile" AfterTargets="FindReferenceAssembliesForReferences">
		<ItemGroup>
			<ReferencePathWithRefAssemblies Remove="@(ReferencePathWithRefAssemblies)" Condition="%(Filename) != 'Corlib'" />
			<ReferencePath Remove="@(ReferencePath)" />
		</ItemGroup>
	</Target>
	<ItemGroup>
	  <Compile Remove="Portable\**" />
	  <EmbeddedResource Remove="Portable\**" />
	  <None Remove="Portable\**" />
	</ItemGroup>

	<ItemGroup>
		<!-- Only include native libs if they exist locally to avoid LNK1181 in environments without them -->
		<NativeLibrary Include="$(MSBuildStartupDirectory)\..\x64\Debug\NativeLib.lib" Condition="Exists('$(MSBuildStartupDirectory)\..\x64\Debug\NativeLib.lib')" />
		<NativeLibrary Include="$(MSBuildStartupDirectory)\..\x64\Debug\LibC.lib" Condition="Exists('$(MSBuildStartupDirectory)\..\x64\Debug\LibC.lib')" />
		<NativeLibrary Include="$(MSBuildStartupDirectory)\..\x64\Debug\Doom.lib" Condition="Exists('$(MSBuildStartupDirectory)\..\x64\Debug\Doom.lib')" />
		<!-- CPUID object file for CPU feature detection - using safe pointer-based version -->
		<NativeLibrary Include="$(MSBuildProjectDirectory)\cpuid_safe.obj" Condition="Exists('$(MSBuildProjectDirectory)\cpuid_safe.obj')" />
		<!-- Stubs for missing native symbols (built from native_stubs.asm) -->
		<NativeLibrary Include="$(MSBuildProjectDirectory)\native_stubs.obj" Condition="Exists('$(MSBuildProjectDirectory)\native_stubs.obj')" />
	</ItemGroup>

	<!-- Build NASM stubs if the real native libs are not present. -->
	<Target Name="BuildNativeStubs" BeforeTargets="Build" Condition="Exists('$(MSBuildProjectDirectory)\native_stubs.asm')">
		<PropertyGroup>
			<_NasmExe Condition="Exists('$(MSBuildStartupDirectory)\Tools\nasm.exe')">$(MSBuildStartupDirectory)\Tools\nasm.exe</_NasmExe>
			<_NasmExe Condition="'$(_NasmExe)'=='' and Exists('$(MSBuildProjectDirectory)\..\Tools\nasm.exe')">$(MSBuildProjectDirectory)\..\Tools\nasm.exe</_NasmExe>
		</PropertyGroup>
		<Message Text="[Native] Building native stubs via NASM: $(_NasmExe)" Importance="high" />
		<Exec Condition="'$(_NasmExe)' != ''" Command="&quot;$(_NasmExe)&quot; -f win64 &quot;$(MSBuildProjectDirectory)\native_stubs.asm&quot; -o &quot;$(MSBuildProjectDirectory)\native_stubs.obj&quot;" />
		<Warning Condition="'$(_NasmExe)' == ''" Text="NASM not found; cannot build native stubs. Install NASM or provide native libraries implementing required symbols." />
	</Target>

	<ItemGroup>
		<LinkerArg Include="/fixed /base:0x10000000 /map:Kernel.map" />
		<LinkerArg Include="/FORCE:UNRESOLVED" />
		<!-- Force include KMainWrapper from native_stubs.obj so it's not stripped -->
		<LinkerArg Include="/INCLUDE:KMainWrapper" />
	</ItemGroup>

	<!--Warning: This package is modified(/packages). Using official one may cause it fail to compile!-->
  <ItemGroup>
    <PackageReference Include="Microsoft.DotNet.ILCompiler" Version="7.0.0-alpha.1.22074.1" />
  </ItemGroup>

	<!-- Manually define PackageDefinitions to fix ILCompiler -->
	<ItemGroup>
		<PackageDefinitions Include="Microsoft.DotNet.ILCompiler">
			<Name>Microsoft.DotNet.ILCompiler</Name>
			<ResolvedPath>$(NuGetPackageRoot)microsoft.dotnet.ilcompiler\7.0.0-alpha.1.22074.1\</ResolvedPath>
		</PackageDefinitions>
		<PackageDefinitions Include="runtime.win-x64.Microsoft.DotNet.ILCompiler">
			<Name>runtime.win-x64.Microsoft.DotNet.ILCompiler</Name>
			<ResolvedPath>$(NuGetPackageRoot)runtime.win-x64.microsoft.dotnet.ilcompiler\7.0.0-alpha.1.22074.1\</ResolvedPath>
		</PackageDefinitions>
	</ItemGroup>

	<Import Project="..\Kernel\Kernel.projitems" Label="Shared" />

	<!-- Ensure native output directory exists for loader.o and native exe -->
	<Target Name="EnsureNativeOutDir" BeforeTargets="BuildISO">
		<PropertyGroup>
			<NativeOutDir>$(MSBuildProjectDirectory)\$(NativeOutputPath)</NativeOutDir>
		</PropertyGroup>
		<MakeDir Directories="$(NativeOutDir)" Condition="!Exists('$(NativeOutDir)')" />
	</Target>

	<!-- Improved BuildISO target: tolerate locked ramdisk.tar -->
	<Target Name="BuildISO" AfterTargets="Publish" Condition="'$(SkipISO)'!='true'">
		<PropertyGroup>
			<RamdiskPath>$(MSBuildStartupDirectory)\Tools\grub2\boot\ramdisk.tar</RamdiskPath>
			<RamdiskTemp>$(MSBuildStartupDirectory)\Tools\grub2\boot\ramdisk.new.tar</RamdiskTemp>
			<LoaderPath>$(MSBuildProjectDirectory)\$(NativeOutputPath)loader.o</LoaderPath>
			<KernelPath>$(MSBuildProjectDirectory)\$(NativeOutputPath)$(TargetName)$(NativeBinaryExt)</KernelPath>
			<KernelBin>$(MSBuildStartupDirectory)\Tools\grub2\boot\kernel.bin</KernelBin>
		</PropertyGroup>
		<!-- Try delete (ignore failure if locked) -->
		<Delete Files="$(RamdiskPath)" ContinueOnError="true" />
		<!-- Create new archive to temp to avoid locking conflicts -->
		<Exec Command="&quot;$(MSBuildStartupDirectory)\Tools\7-Zip\7z.exe&quot; a &quot;$(RamdiskTemp)&quot; &quot;$(MSBuildStartupDirectory)\Ramdisk\*&quot;" />
		<!-- Replace original if delete succeeded or if overwrite permitted -->
		<Exec Command="cmd.exe /c move /y &quot;$(RamdiskTemp)&quot; &quot;$(RamdiskPath)&quot;" ContinueOnError="true" />
		<Exec WorkingDirectory="$(MSBuildStartupDirectory)\Tools\" Command="&quot;$(MSBuildStartupDirectory)\Tools\nasm.exe&quot; -fbin &quot;$(MSBuildStartupDirectory)\Tools\Trampoline.asm&quot; -o &quot;$(MSBuildStartupDirectory)\Tools\trampoline.o&quot;" />
		<Exec WorkingDirectory="$(MSBuildStartupDirectory)\Tools\" Command="&quot;$(MSBuildStartupDirectory)\Tools\nasm.exe&quot; -fbin &quot;$(MSBuildStartupDirectory)\Tools\EntryPoint.asm&quot; -o &quot;$(LoaderPath)&quot;" />
		<!-- Concatenate loader and native exe only if both exist -->
		<PropertyGroup>
			<LoaderPath>$(MSBuildProjectDirectory)\$(NativeOutputPath)loader.o</LoaderPath>
			<KernelPath>$(MSBuildProjectDirectory)\$(NativeOutputPath)$(TargetName)$(NativeBinaryExt)</KernelPath>
			<KernelBin>$(MSBuildStartupDirectory)\Tools\grub2\boot\kernel.bin</KernelBin>
		</PropertyGroup>
		<Exec Command="cmd.exe /c copy /b &quot;$(LoaderPath)&quot;+&quot;$(KernelPath)&quot; &quot;$(KernelBin)&quot;" Condition="Exists('$(LoaderPath)') AND Exists('$(KernelPath)')" />
		<Delete Files="$(LoaderPath)" />
		<Delete Files="$(MSBuildStartupDirectory)\Tools\trampoline.o" />
		<Exec Command="&quot;$(MSBuildStartupDirectory)\Tools\mkisofs.exe&quot; -relaxed-filenames -J -R -o &quot;$(MSBuildProjectDirectory)\$(NativeOutputPath)$(TargetName).iso&quot; -b boot/grub/i386-pc/eltorito.img -no-emul-boot -boot-load-size 4 -boot-info-table &quot;$(MSBuildStartupDirectory)\Tools\grub2&quot;" />
	</Target>

