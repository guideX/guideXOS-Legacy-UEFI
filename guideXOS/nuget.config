<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Local custom/modified packages (checked first) -->
    <add key="Local" value="../packages" />
    
    <!-- Official NuGet.org (fallback for other packages) -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  
  <packageSourceMapping>
    <!-- Force ILCompiler to use local packages only -->
    <packageSource key="Local">
      <package pattern="Microsoft.DotNet.ILCompiler" />
      <package pattern="runtime.win-x64.Microsoft.DotNet.ILCompiler" />
    </packageSource>
    
    <!-- All other packages come from NuGet.org -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
